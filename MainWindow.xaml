<Window x:Class="tool_r1ng.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:tool_r1ng.Controls"
        xmlns:local="clr-namespace:tool_r1ng"
        mc:Ignorable="d"
        Title="tool_r1ng"
        Width="760"
        Height="64"
        MinWidth="520"
        MinHeight="64"
        MaxHeight="500"
        Background="Transparent"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Width="48"
                                Height="26"
                                Background="#AADCD6CB"
                                CornerRadius="13">
                            <Ellipse x:Name="Knob"
                                     Width="20"
                                     Height="20"
                                     Margin="3"
                                     HorizontalAlignment="Left"
                                     Fill="#FFFFFF" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource LauncherAccentBrush}" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource LauncherTextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource LauncherAccentBrush}" />
            <Setter Property="SelectionBrush" Value="#805ca7ff" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Height" Value="51" />
            <Setter Property="Margin" Value="10,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Row"
                                Padding="10,7"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#88FFF7EF" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#A8FFF7EF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#B8EAF3F2" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#5bcffa" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootMaterial"
            Background="#AAFFFFFF"
            BorderBrush="#8FD6D0C3"
            BorderThickness="1"
            CornerRadius="10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition />
                <RowDefinition Height="12" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderMaterial"
                    Grid.Row="0"
                    Background="#99FFFFFF"
                    BorderBrush="#80E4DECF"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>

                    <Border Width="34"
                            Height="34"
                            Background="#175cbdff"
                            CornerRadius="8">
                        <TextBlock Style="{StaticResource IconText}"
                                   FontSize="18"
                                   Foreground="{StaticResource LauncherAccentBrush}"
                                   Text="&#xE721;" />
                    </Border>

                    <TextBox x:Name="QueryBox"
                             Grid.Column="1"
                             TextOptions.TextFormattingMode="Display"
                             Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="2"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding HideCommand}"
                            Cursor="Hand"
                            ToolTip="Close">
                        <TextBlock FontSize="14"
                                   Foreground="{StaticResource LauncherMutedBrush}"
                                   Text="x" />
                    </Button>
                </Grid>
            </Border>

            <Border x:Name="SettingsMaterial"
                    Grid.Row="1"
                    Margin="16,12,16,4"
                    Padding="16,12"
                    Background="#9EFFFFFF"
                    BorderBrush="#80E4DECF"
                    BorderThickness="1"
                    CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       Text="设置" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource LauncherMutedBrush}"
                                       Text="{Binding EverythingStatusText}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                MinWidth="74"
                                Height="24"
                                Padding="10,0"
                                VerticalAlignment="Center"
                                Background="#B8F1ECE0"
                                CornerRadius="8">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#586062"
                                       Text="Everything" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,10,0,8"
                            Background="#90EFE7DA" />

                    <Grid Grid.Row="2"
                          MinHeight="46">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       Text="文件搜索" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource LauncherMutedBrush}"
                                       Text="使用 Everything 索引搜索本地文件" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource SettingsSwitch}"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding EverythingFileSearchEnabled, Mode=OneWay}"
                                      Click="EverythingFileSearchToggle_Click" />
                    </Grid>

                    <Grid Grid.Row="3"
                          MinHeight="46"
                          Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       Text="应用搜索" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource LauncherMutedBrush}"
                                       Text="使用 Everything 索引加载开始菜单和桌面应用" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource SettingsSwitch}"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding EverythingAppSearchEnabled, Mode=OneWay}"
                                      Click="EverythingAppSearchToggle_Click" />
                    </Grid>

                    <Grid Grid.Row="4"
                          MinHeight="46"
                          Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       Text="亚克力玻璃" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource LauncherMutedBrush}"
                                       Text="使用系统亚克力背景效果" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource SettingsSwitch}"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding AcrylicBackdropEnabled, Mode=OneWay}"
                                      Click="AcrylicBackdropToggle_Click" />
                    </Grid>

                    <Grid Grid.Row="5"
                          MinHeight="44"
                          Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LauncherTextBrush}"
                                   Text="背景不透明度" />

                        <Slider Grid.Column="1"
                                Minimum="0.15"
                                Maximum="0.90"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="False"
                                IsEnabled="{Binding AcrylicBackdropEnabled, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Value="{Binding AcrylicOpacity, Mode=OneWay}"
                                ValueChanged="AcrylicOpacitySlider_ValueChanged" />

                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource LauncherMutedBrush}"
                                   Text="{Binding AcrylicOpacityPercent}" />
                    </Grid>
                </Grid>
            </Border>

            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     Margin="6,10,6,4"
                     ItemsSource="{Binding Results}"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"
                     SelectedItem="{Binding SelectedResult, Mode=TwoWay}">
                <ListBox.Style>
                    <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsResultsVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="34"
                                    Height="34"
                                    Background="#A8FFFFFF"
                                    BorderBrush="#86E4DECF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Image Width="22"
                                           Height="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="{Binding IconImage}">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <TextBlock FontSize="15"
                                               Foreground="{StaticResource LauncherAccentBrush}"
                                               Text="{Binding IconGlyph}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource IconText}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="0,-1,0,0">
                                <controls:HighlightedTextBlock FontSize="15"
                                                               FontWeight="Normal"
                                                               Foreground="{StaticResource LauncherTextBrush}"
                                                               PlainText="{Binding Title}"
                                                               Segments="{Binding HighlightedTitle}"
                                                               TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,1,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource LauncherMutedBrush}"
                                           Text="{Binding Subtitle}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <Button Width="30"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Padding="0"
                                        Background="#B8F7F3EA"
                                        BorderBrush="#8FE1D8CA"
                                        BorderThickness="1"
                                        Click="InlineActionButton_Click"
                                        Cursor="Hand"
                                        ToolTip="{Binding InlineActionToolTip}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasInlineAction}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Style="{StaticResource IconText}"
                                               FontSize="14"
                                               Foreground="{StaticResource LauncherMutedBrush}"
                                               Text="{Binding InlineActionGlyph}" />
                                </Button>

                                <Button Width="30"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Padding="0"
                                        Background="#B8F7F3EA"
                                        BorderBrush="#8FE1D8CA"
                                        BorderThickness="1"
                                        Click="SecondaryActionButton_Click"
                                        Cursor="Hand"
                                        ToolTip="{Binding SecondaryActionToolTip}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSecondaryAction}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Style="{StaticResource IconText}"
                                               FontSize="14"
                                               Foreground="{StaticResource LauncherMutedBrush}"
                                               Text="{Binding SecondaryActionGlyph}" />
                                </Button>

                                <Border MinWidth="58"
                                        Height="24"
                                        Padding="9,0"
                                        VerticalAlignment="Center"
                                        Background="#B8F1ECE0"
                                        CornerRadius="8">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="#586062"
                                               Text="{Binding ProviderName}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2"
                  Margin="18,0,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource LauncherMutedBrush}"
                           Text="{Binding StatusText}" />

                
            </Grid>
        </Grid>
    </Border>
</Window>
