<Window x:Class="tool_r1ng.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tool_r1ng"
        mc:Ignorable="d"
        Title="tool_r1ng"
        Width="760"
        Height="500"
        MinWidth="520"
        MinHeight="420"
        AllowsTransparency="True"
        Background="Transparent"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource LauncherTextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource LauncherAccentBrush}" />
            <Setter Property="SelectionBrush" Value="#8029B3A8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="10,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Row"
                                Padding="12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#FFF7EF" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#ECD8BE" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#EAF3F2" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#8BC7BF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FFFCF7"
            BorderBrush="#272C2E"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34"
                              Color="#151515"
                              Direction="270"
                              Opacity="0.25"
                              ShadowDepth="16" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="96" />
                <RowDefinition Height="*" />
                <RowDefinition Height="34" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="#E4DECF"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>

                    <Border Width="34"
                            Height="34"
                            Background="#EAF3F2"
                            CornerRadius="8">
                        <TextBlock Style="{StaticResource IconText}"
                                   FontSize="18"
                                   Foreground="{StaticResource LauncherAccentBrush}"
                                   Text="&#xE721;" />
                    </Border>

                    <TextBox x:Name="QueryBox"
                             Grid.Column="1"
                             Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="2"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding HideCommand}"
                            Cursor="Hand"
                            ToolTip="Close">
                        <TextBlock FontSize="14"
                                   Foreground="{StaticResource LauncherMutedBrush}"
                                   Text="x" />
                    </Button>
                </Grid>
            </Border>

            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     Margin="6,10,6,4"
                     ItemsSource="{Binding Results}"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"
                     SelectedItem="{Binding SelectedResult, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="34"
                                    Height="34"
                                    Background="#FFFFFF"
                                    BorderBrush="#E4DECF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <TextBlock Style="{StaticResource IconText}"
                                           FontSize="17"
                                           Foreground="{StaticResource LauncherAccentBrush}"
                                           Text="{Binding IconGlyph}" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource LauncherTextBrush}"
                                           Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource LauncherMutedBrush}"
                                           Text="{Binding Subtitle}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <Border Grid.Column="2"
                                    MinWidth="58"
                                    Height="24"
                                    Padding="9,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#F1ECE0"
                                    CornerRadius="8">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#586062"
                                           Text="{Binding ProviderName}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2"
                  Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource LauncherMutedBrush}"
                           Text="{Binding StatusText}" />

                <ProgressBar Grid.Column="1"
                             Width="76"
                             Height="3"
                             VerticalAlignment="Center"
                             Background="#EAE3D5"
                             BorderThickness="0"
                             Foreground="{StaticResource LauncherAccentBrush}"
                             IsIndeterminate="{Binding IsSearching}" />
            </Grid>
        </Grid>
    </Border>
</Window>
